# Winuel Backend Production Environment Configuration
# 云纽论坛后端生产环境配置示例
#
# IMPORTANT: This file is for reference only. DO NOT commit actual secrets to version control.
# 重要：此文件仅供参考。不要将实际的密钥提交到版本控制系统。
#
# Secrets should be set using Wrangler CLI:
# 密钥应该使用 Wrangler CLI 设置：
#   wrangler secret put JWT_SECRET
#   wrangler secret put RESEND_API_KEY
#   wrangler secret put GITHUB_CLIENT_ID
#   wrangler secret put GITHUB_CLIENT_SECRET

# ============================================================================
# Security Secrets (Must be set via wrangler secret)
# 安全密钥（必须通过 wrangler secret 设置）
# ============================================================================

# JWT Secret - Required for authentication
# JWT 密钥 - 认证必需
# Minimum length: 32 characters
# 最小长度：32个字符
# Command: wrangler secret put JWT_SECRET
# Example: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Value: [Use a strong random string]

# Resend API Key - Required for email service
# Resend API 密钥 - 邮件服务必需
# Get your API key from: https://resend.com/api-keys
# Command: wrangler secret put RESEND_API_KEY
# Example: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Value: [Your Resend API key]

# GitHub OAuth Client ID - Required for GitHub login
# GitHub OAuth 客户端 ID - GitHub 登录必需
# Get your credentials from: https://github.com/settings/developers
# Command: wrangler secret put GITHUB_CLIENT_ID
# Example: Iv23li...
# Value: [Your GitHub OAuth App Client ID]

# GitHub OAuth Client Secret - Required for GitHub login
# GitHub OAuth 客户端密钥 - GitHub 登录必需
# Get your credentials from: https://github.com/settings/developers
# Command: wrangler secret put GITHUB_CLIENT_SECRET
# Example: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Value: [Your GitHub OAuth App Client Secret]

# ============================================================================
# Public Configuration (Set in wrangler.toml)
# 公共配置（在 wrangler.toml 中设置）
# ============================================================================

# Environment
# 环境变量
ENVIRONMENT=production

# Email Configuration
# 邮件配置
RESEND_FROM_EMAIL=noreply@mail.winuel.com
RESEND_FROM_NAME=云纽论坛

# API Base URL (Used for OAuth callbacks)
# API 基础 URL（用于 OAuth 回调）
API_URL=https://api.winuel.com

# GitHub OAuth Redirect URI
# GitHub OAuth 重定向 URI
# This will be automatically constructed as: ${API_URL}/api/auth/github/callback
# 这将自动构建为：${API_URL}/api/auth/github/callback
GITHUB_REDIRECT_URI=https://api.winuel.com/api/auth/github/callback

# ============================================================================
# Setup Instructions
# 设置说明
# ============================================================================

# 1. Set JWT Secret
# 设置 JWT 密钥
#   wrangler secret put JWT_SECRET
#   [Paste your 32+ character random string]

# 2. Set Resend API Key
# 设置 Resend API 密钥
#   wrangler secret put RESEND_API_KEY
#   [Paste your Resend API key]

# 3. Set GitHub OAuth Credentials
# 设置 GitHub OAuth 凭证
#   wrangler secret put GITHUB_CLIENT_ID
#   [Paste your GitHub Client ID]
#
#   wrangler secret put GITHUB_CLIENT_SECRET
#   [Paste your GitHub Client Secret]

# 4. Deploy to Cloudflare Workers
# 部署到 Cloudflare Workers
#   npm run build
#   wrangler deploy

# ============================================================================
# Verification
# 验证
# ============================================================================

# After deployment, verify services are running:
# 部署后，验证服务是否正常运行：
#
# 1. Check health endpoint:
#    检查健康端点：
#    curl https://api.winuel.com/health
#
# 2. Test OAuth configuration:
#    测试 OAuth 配置：
#    curl https://api.winuel.com/api/auth/github/test
#
# 3. Test email service:
#    测试邮件服务：
#    (Email service availability will be shown in /health endpoint)

# ============================================================================
# Common Issues
# 常见问题
# ============================================================================

# Issue: OAuth returns "CONFIG_ERROR"
# 问题：OAuth 返回 "CONFIG_ERROR"
# Solution: Make sure GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET are set via wrangler secret
# 解决方案：确保 GITHUB_CLIENT_ID 和 GITHUB_CLIENT_SECRET 通过 wrangler secret 设置

# Issue: Email verification codes not sending
# 问题：邮件验证码无法发送
# Solution: Make sure RESEND_API_KEY is set via wrangler secret and is valid
# 解决方案：确保 RESEND_API_KEY 通过 wrangler secret 设置且有效

# Issue: JWT authentication fails
# 问题：JWT 认证失败
# Solution: Make sure JWT_SECRET is set via wrangler secret and is at least 32 characters
# 解决方案：确保 JWT_SECRET 通过 wrangler secret 设置且至少 32 个字符

# ============================================================================
# Security Best Practices
# 安全最佳实践
# ============================================================================

# 1. Never commit actual secrets to version control
#    永远不要将实际的密钥提交到版本控制系统

# 2. Use strong, random secrets
#    使用强随机密钥
#    - Generate JWT secret: openssl rand -base64 32
#    - Use Resend's API key from their dashboard
#    - Use GitHub OAuth credentials from their developer settings

# 3. Regularly rotate secrets
#    定期轮换密钥

# 4. Monitor usage and suspicious activity
#    监控使用情况和可疑活动

# 5. Keep wrangler.toml in sync with actual configuration
#    保持 wrangler.toml 与实际配置同步