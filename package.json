{"name": "cloudlink", "version": "1.0.0", "description": "CloudLink Forum - A modern forum system based on cloud-native technology", "private": true, "workspaces": ["packages/*", "frontend", "backend", "admin-pages"], "scripts": {"dev": "pnpm --filter frontend dev & pnpm --filter backend dev", "dev:backend": "pnpm --filter backend dev", "dev:frontend": "pnpm --filter frontend dev", "dev:admin": "pnpm --filter admin-pages dev", "build": "pnpm --filter backend build && pnpm --filter frontend build && pnpm --filter admin-pages build", "build:shared": "pnpm --filter \"@cloudlink/shared-*\" build", "build:backend": "pnpm --filter backend build", "build:frontend": "pnpm --filter frontend build", "build:admin": "pnpm --filter admin-pages build", "lint": "pnpm --filter frontend lint && pnpm --filter backend lint", "lint:backend": "pnpm --filter backend lint", "lint:frontend": "pnpm --filter frontend lint", "clean": "pnpm --filter backend clean && pnpm --filter frontend clean && pnpm --filter admin-pages clean", "clean:backend": "cd backend && rm -rf dist node_modules/.cache", "clean:frontend": "cd frontend && rm -rf dist node_modules/.cache", "clean:admin": "cd admin-pages && rm -rf dist node_modules/.cache", "install:all": "pnpm install", "prepare": "husky install", "format": "prettier --write ."}, "keywords": ["forum", "cloudflare", "workers", "vue", "typescript", "fullstack"], "author": "Lemon Studio", "license": "MIT", "devDependencies": {"concurrently": "^8.2.2", "husky": "^9.1.7", "lint-staged": "^15.2.11", "@commitlint/cli": "^19.6.1", "@commitlint/config-conventional": "^19.6.0"}, "optionalDependencies": {"@rollup/rollup-linux-x64-gnu": "^4.59.0", "@rollup/rollup-darwin-x64": "^4.59.0", "@rollup/rollup-win32-x64-msvc": "^4.59.0"}, "lint-staged": {"*.{js,jsx,ts,tsx,vue}": ["eslint --fix", "prettier --write"], "*.{json,md}": ["prettier --write"]}, "engines": {"node": ">=18.0.0", "npm": ">=9.0.0"}}