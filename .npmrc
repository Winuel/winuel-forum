# 配置 npm 依赖安装行为
# 确保可选依赖被正确安装，特别是 Rollup 的原生模块
legacy-peer-deps=false

# 优化构建性能
prefer-offline=true

# 确保平台特定依赖被正确解析
# Rollup 需要原生模块来提高性能
# 在 Cloudflare Pages (Linux) 环境中，确保使用正确的原生模块
# 这些依赖会根据平台自动选择对应的版本
# - Linux: @rollup/rollup-linux-x64-gnu
# - macOS: @rollup/rollup-darwin-x64
# - Windows: @rollup/rollup-win32-x64-msvc